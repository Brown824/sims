# ═══════════════════════════════════════════════════════════════
#  SIMS Backend — Environment Variables
#  Copy this file to `.env` and fill in your real values.
#  `.env` is gitignored and should NEVER be committed.
# ═══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────
APP_NAME=SIMS
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=True
PORT=8000

# ── VirusTotal ───────────────────────────
# Get your free API key from: https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# ── Database ─────────────────────────────
# For local development SQLite is used by default.
# For production, switch to MongoDB Atlas:
DB_BACKEND=sqlite
SQLITE_PATH=./sims.db
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/sims?retryWrites=true&w=majority
# MONGODB_DB_NAME=sims

# ── ML Model ─────────────────────────────
MODEL_PATH=./data/models/sims_model.h5
TFLITE_MODEL_PATH=./data/models/sims_offline.tflite
MODEL_VERSION=1.0.0

# ── Thresholds ───────────────────────────
# Spam block threshold: ≥ 0.85 → BLOCK
SPAM_BLOCK_THRESHOLD=0.85
# Spam warn threshold: 0.60–0.84 → WARN
SPAM_WARN_THRESHOLD=0.60

# ── Security ─────────────────────────────
# Change this to a strong random string for production!
ADMIN_API_KEY=change_me

# ── CORS ─────────────────────────────────
# Comma-separated list of allowed origins (use "*" for dev)
ALLOWED_ORIGINS=*

# ── Logging ──────────────────────────────
LOG_LEVEL=INFO

# ── Rate Limiting ────────────────────────
VT_REQUESTS_PER_MINUTE=4
VT_REQUESTS_PER_DAY=500

