# ─────────────────────────────────────────────
#  SIMS Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to Git.
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
APP_NAME=SIMS
APP_ENV=development          # development | production
APP_VERSION=1.0.0
DEBUG=true
PORT=8000

# ── VirusTotal ───────────────────────────────
# Get free API key at: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here
VIRUSTOTAL_BASE_URL=https://www.virustotal.com/api/v3

# ── Database ─────────────────────────────────
# MongoDB Atlas: create free cluster at https://mongodb.com/atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/sims?retryWrites=true&w=majority
MONGODB_DB_NAME=sims

# SQLite (local dev fallback — no URI needed, just path)
SQLITE_PATH=./sims.db

# Use 'mongodb' or 'sqlite' to switch
DB_BACKEND=sqlite

# ── ML Model ─────────────────────────────────
MODEL_PATH=./data/models/sims_model.h5
TFLITE_MODEL_PATH=./data/models/sims_offline.tflite
MODEL_VERSION=1.0.0

# ── Spam Detection Thresholds ─────────────────
SPAM_BLOCK_THRESHOLD=0.85
SPAM_WARN_THRESHOLD=0.60

# ── Security ─────────────────────────────────
# Admin API key for /retrain endpoint
ADMIN_API_KEY=change_this_to_a_strong_random_secret

# ── CORS ─────────────────────────────────────
# Comma-separated allowed origins (use * for dev only)
ALLOWED_ORIGINS=*

# ── Logging ──────────────────────────────────
LOG_LEVEL=INFO    # DEBUG | INFO | WARNING | ERROR

# ── Rate Limiting ────────────────────────────
VT_REQUESTS_PER_MINUTE=4   # VirusTotal free tier limit
VT_REQUESTS_PER_DAY=500
